{
  "name": "TrustArmor GRC",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "forwardPorts": [3000, 8000, 5432, 6379],
  "portsAttributes": {
    "3000": {
      "label": "Next.js Frontend",
      "onAutoForward": "openBrowser"
    },
    "8000": {
      "label": "Go Backend API (internal - use port 3000)",
      "onAutoForward": "silent"
    },

    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "ignore"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "ignore"
    }
  },
  "containerEnv": {
    "DATABASE_URL": "postgres://postgres:postgres@localhost:5432/grc?sslmode=disable",
    "JWT_SECRET": "trustarmor_development_secret_key_1234567890",
    "REDIS_URL": "redis://localhost:6379",
    "PORT": "8000"
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "remoteUser": "codespace",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next"
      ]
    }
  }
}
