# Database & Redis Config
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/grc?sslmode=disable
REDIS_URL=redis://localhost:6379

# Server Config
PORT=8000
FRONTEND_URL=http://localhost:3000

# Live SMTP Email Settings (To send real emails to inboxes)
# Leave empty for Development Mode (logs emails to Go backend terminal console & UI preview popup)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@trustarmor.io
